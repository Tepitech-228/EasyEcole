{
  "name": "easy-ecole-orientation-backend",
  "version": "1.0.0",
  "description": "Backend du projet Easy Ecole",
  "main": "index.js",
  "scripts": {
    "dev": "nodemon src/app.ts",
    "start": "node index.js",
    "start:server": "ts-node src/app.ts",
    "types": "tsc",
    "build": "babel src --out-dir lib --copy-files --extensions .ts,.js",
    "db:create": "ts-node src/core/scripts/sync-database.ts",
    "db:sync": "ts-node src/core/scripts/sync-database.ts",
    "db:seed": "ts-node src/core/scripts/seed.ts",
    "db:reset": "ts-node src/core/scripts/reset-database.ts",
    "db:setup": "ts-node src/core/scripts/reset-database.ts",
    "db:seed-bulletins": "ts-node src/core/scripts/seed-bulletins.ts",
    "db:sync-reporting": "ts-node src/core/scripts/sync-reporting.ts",
    "db:seed-esa": "ts-node src/core/scripts/seed-esa.ts",^|    "test": "jest",^|    "test:watch": "jest --watch",^|    "test:coverage": "jest --coverage"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
